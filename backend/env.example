# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/evosense

# Redis
REDIS_URL=redis://redis:6379/0

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Reports sync (incremental metrics - n8n/cron, generate with: openssl rand -hex 32)
REPORTS_SYNC_API_KEY=

# AI/N8N
N8N_AI_WEBHOOK=https://your-n8n-instance.com/webhook/ai-analysis
# LibreChat (plug agentes): URL base e API key. Se definidos, a Secretária usa LibreChat quando o agente secretaria tiver librechat_agent_id.
# LIBRECHAT_URL=http://mentor:3000
# LIBRECHAT_API_KEY=
N8N_RAG_WEBHOOK_URL=https://your-n8n-instance.com/webhook/rag-upsert
# Opcional: webhook n8n para remover resumo do pgvector (ao reprovar ou antes de reprocessar)
N8N_RAG_REMOVE_WEBHOOK_URL=
N8N_SUMMARIZE_WEBHOOK_URL=https://your-n8n-instance.com/webhook/summarize
# Chave única para acessar a página /admin/bia (config e teste da BIA). Quem tiver a chave acessa.
BIA_ADMIN_ACCESS_KEY=
N8N_AUDIO_WEBHOOK=https://your-n8n-instance.com/webhook/audio-transcribe
N8N_TRIAGE_WEBHOOK=https://your-n8n-instance.com/webhook/ai-triage
N8N_MODELS_WEBHOOK=https://your-n8n-instance.com/webhook/models
AI_MODEL_NAME=qwen-local
AI_EMBEDDING_MODEL=qwen-mini-embeddings

# Dify + WhatsApp (read receipts antes do Dify; indicador digitando ~N s antes de enfileirar resposta)
# DIFY_MARK_INBOUND_READ=True
# DIFY_MARK_INBOUND_READ_MAX_MESSAGES=30
#   (0 = marcar todas as inbound do batch; >0 = só as N mais recentes)
# DIFY_PRE_SEND_TYPING=True
# DIFY_PRE_SEND_TYPING_SECONDS=1.2

# Evolution API
EVO_BASE_URL=https://your-evolution-api.com
EVO_API_KEY=your-evolution-api-key

# RabbitMQ (Railway plugin ou local)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Celery (default: mesmo broker que RABBITMQ_URL; worker separado para debounce inbound Dify)
# CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
# CELERY_TASK_DEFAULT_QUEUE=celery
# CELERY_TASK_ALWAYS_EAGER=false

# ----- Staging / API oficial Meta (webhook) -----
# Ver docs/STAGING_RAILWAY.md
# WHATSAPP_CLOUD_VERIFY_TOKEN=token_secreto_para_verificacao_webhook
# WHATSAPP_CLOUD_APP_SECRET=app_secret_do_meta_developers

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
